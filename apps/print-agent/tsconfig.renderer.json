{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "target": "ES2022",
    "lib": ["dom", "es2022"],
    "rootDir": "src",
    "outDir": "dist",
    "noEmit": false,
    "incremental": false
  },
  "include": [
    "src/renderer/**/*.ts",
    "src/shared/**/*.ts"
  ]
}
